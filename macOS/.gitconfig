[alias]
  hist = "log --graph --date=short --pretty=format:'%C(auto)%h %ad | %s%d %C(blue)[%an]'"
  gr = "log --graph --full-history --all --pretty=tformat:'%C(red)%h%C(reset) %C(auto)%d%C(reset) %s %C(yellow)(%an)%C(reset)'"
  uncommit = reset --soft HEAD^
  unstage = reset
  staged = diff --cached
[color]
  ui = true
[credential]
  helper = osxkeychain
[core]
  autocrlf = false
  safecrlf = true
  editor = nvim
  excludesfile = ~/.gitignore_global
[filter "lfs"]
  clean = git lfs clean %f
  smudge = git lfs smudge %f
  required = true
  process = git-lfs filter-process
[format]
  pretty = %Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset
[github]
  user = zlahham
[push]
  default = simple
[pull]
  rebase = true
[user]
  email = zaid@lahham.tech
  name = Zaid Lahham
  signingkey = 5D15AD6B6905503B
[commit]
  gpgsign = true
[gpg]
  program = /opt/homebrew/bin/gpg
[includeIf "gitdir:/Users/zaid/workspace/revie/"]
  path = /Users/zaid/workspace/revie/.gitconfig
[init]
  defaultBranch = main
